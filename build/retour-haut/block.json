{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gn2025/retour-haut",
  "version": "0.1.0",
  "title": "Back to Top",
  "category": "gn-block-theme",
  "icon": "insert-before",
  "description": "Template button to go back to the top of the page.",
  "example": {},
  "attributes": {
    "rightPosition": {
      "type": "number",
      "default": 15
    },
    "bottomPosition": {
      "type": "number",
      "default": 15
    },
    "scrollTrigger": {
      "type": "number",
      "default": 300
    },
    "iconSize": {
      "type": "number",
      "default": 64
    }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": true,
    "spacing": {
      "padding": true,
      "margin": true
    }
  },
  "textdomain": "gn-block-react",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}