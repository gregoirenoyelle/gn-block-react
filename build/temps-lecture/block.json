{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gn2025/temps-lecture",
  "version": "0.1.0",
  "title": "Reading Time",
  "category": "gn-block-theme",
  "icon": "clock",
  "description": "Adds the reading time for the article",
  "example": {},
  "attributes": {
    "prefixText": {
      "type": "string",
      "default": ""
    },
    "timeUnit": {
      "type": "string",
      "default": "min."
    }
  },
  "supports": {
    "html": false,
    "color": {
      "text": true,
      "background": false
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true,
      "__experimentalFontWeight": true
    },
    "spacing": {
      "margin": true
    },
    "multiple": true,
    "className": true
  },
  "textdomain": "gn-block-react",
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}